# Hyperliquid Configuration
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WALLET_ADDRESS=your_wallet_address_here
HYPERLIQUID_PRIVATE_KEY=your_private_key_here

# AWS Configuration — for reading Hyperliquid's source archive (requester-pays, AWS only)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# Object store — YOUR OWN S3-compatible bucket (Cloudflare R2 recommended: no egress fees).
# Caches raw archive pulls (pull each object from AWS once, re-read from here) and
# mirrors processed output. Needs its OWN credentials, separate from the AWS keys above.
# Leave OBJECT_STORE_BUCKET blank to disable (data stays on local disk).
# For Cloudflare R2: endpoint = https://<account_id>.r2.cloudflarestorage.com, region = auto.
OBJECT_STORE_BACKEND=auto                 # auto | r2 | s3 | local | none
OBJECT_STORE_ENDPOINT_URL=                # blank = AWS S3; set for R2/Backblaze/MinIO
OBJECT_STORE_BUCKET=
OBJECT_STORE_ACCESS_KEY_ID=
OBJECT_STORE_SECRET_ACCESS_KEY=
OBJECT_STORE_REGION=auto
OBJECT_STORE_PREFIX=                       # optional key prefix, e.g. hyperliquid/
OBJECT_STORE_LOCAL_PATH=./data/object_store  # used when OBJECT_STORE_BACKEND=local

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hyperliquid_data
POSTGRES_USER=hyperliquid
POSTGRES_PASSWORD=your_postgres_password

# InfluxDB Configuration (Time Series)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=hyperliquid
INFLUXDB_BUCKET=market_data

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Data Storage Paths
DATA_ROOT_PATH=./data
HISTORICAL_DATA_PATH=./data/historical
REAL_TIME_DATA_PATH=./data/realtime
LOGS_PATH=./logs

# Monitoring & Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
PROMETHEUS_PORT=8000

# Data Collection Settings
COLLECT_SYMBOLS=BTC,ETH,SOL
HISTORICAL_START_DATE=2023-01-01
REAL_TIME_ENABLED=true
WEBSOCKET_RECONNECT_DELAY=5

# Logging
LOG_LEVEL=INFO
LOG_ROTATION=1 day
LOG_RETENTION=30 days